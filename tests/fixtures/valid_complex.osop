osop_version: "1.0"
id: "test-complex"
name: "Complex Workflow"
description: "A workflow with roles, handoffs, and conditional edges."
nodes:
  - id: "plan"
    type: "agent"
    name: "Plan Phase"
    purpose: "Create execution plan"
    role: "planner"
    success_criteria:
      - "Plan document produced"
    handoff:
      summary_for_next_node: "Plan ready for review"
  - id: "review"
    type: "human"
    name: "Human Review"
    purpose: "Review the plan"
    role: "reviewer"
  - id: "execute"
    type: "cli"
    name: "Execute Plan"
    purpose: "Run the planned steps"
    role: "executor"
  - id: "notify"
    type: "api"
    name: "Send Notification"
    purpose: "Notify stakeholders"
    role: "executor"
edges:
  - from: "plan"
    to: "review"
    mode: "sequential"
  - from: "review"
    to: "execute"
    mode: "conditional"
    when: "approved == true"
  - from: "review"
    to: "plan"
    mode: "fallback"
    label: "Review failed, re-plan"
  - from: "execute"
    to: "notify"
    mode: "sequential"
